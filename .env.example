# CareerBoost AI environment configuration
# Copy this file to .env for local development. Never commit real secrets.

# Application
APP_ENV=development
APP_NAME=CareerBoost AI
APP_DEBUG=false
APP_LOG_LEVEL=INFO

# Frontend
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:5173
BACKEND_MAX_UPLOAD_MB=5
BACKEND_REQUEST_TIMEOUT_SECONDS=30

# Database
POSTGRES_DB=careerboost_ai
POSTGRES_USER=careerboost
POSTGRES_PASSWORD=careerboost_local_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://careerboost:careerboost_local_password@localhost:5432/careerboost_ai

# AI provider
# Version 1.0 keeps the AI provider behind a backend-only infrastructure boundary.
AI_PROVIDER=disabled
AI_API_KEY=
AI_MODEL=
AI_REQUEST_TIMEOUT_SECONDS=30

# Security
UPLOAD_ALLOWED_CONTENT_TYPES=application/pdf
UPLOAD_MAX_FILE_SIZE_BYTES=5242880
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=20

# Observability
LOG_FORMAT=json
ENABLE_CORRELATION_IDS=true
